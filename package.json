{
  "name": "dev-career-ready-monorepo",
  "private": "true",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/shared"
  ],
  "scripts": {
    "clean": "rm -rf node_modules packages/a/node_modules packages/b/node_modules bun.lockb packages/a/bun.lockb packages/b/bun.lockb",
    "dev:web": "bun run --filter web dev",
    "build:web": "bun run --filter web build",
    "dev:api": "bun run --filter api dev",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "type-check": "bunx --bun tsc -b apps/web --noEmit && bun run lint:fix",
    "env:pull:web": "bun run --filter web env:pull"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tanstack/eslint-plugin-query": "5.101.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  },
  "dependencies": {
    "better-auth": "1.6.20",
    "dotenv": "17.4.2",
    "zod": "4.4.3"
  }
}
